# HASH256 GPU Miner Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ─── Wallet ─────────────────────────────────────────────────────────────
# Private key (64 hex chars, with or without 0x prefix)
PRIVATE_KEY=your_private_key_here

# ─── RPC ────────────────────────────────────────────────────────────────
# Free: https://eth.llamarpc.com, https://rpc.ankr.com/eth
# Paid (recommended): Alchemy, Infura, QuickNode
RPC_URL=https://eth.llamarpc.com

# ─── Telegram Notifications (optional) ──────────────────────────────────
# Create a bot via @BotFather, get your chat id via @userinfobot
# Leave empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notification levels (1=on, 0=off)
TELEGRAM_NOTIFY_START=1       # miner started
TELEGRAM_NOTIFY_SOLUTION=1    # solution found (before submit)
TELEGRAM_NOTIFY_SUCCESS=1     # tx confirmed (HASH minted)
TELEGRAM_NOTIFY_FAIL=1        # tx failed / submit error
TELEGRAM_NOTIFY_STOP=1        # miner stopped

# ─── Mining tuning (optional, CLI flags override these) ─────────────────
# BATCH_SIZE=0           # 0 or empty = auto-tune from detected GPU
# THREADS_PER_BLOCK=256
# GAS_PRICE_GWEI=
# GAS_LIMIT=300000
